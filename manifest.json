{
  "manifest_version": 3,
  "name": "Cryo-Wiring Viewer",
  "description": "Open cooldown.yaml files from GitHub in the cryo-wiring viewer",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
